{{- /*
    This is a Go template for chezmoi TOML configuration. It is used to generate
    the actual chezmoi.toml file based on the operating system and hostname.
    The actual file is generated by running `chezmoi init`.

    Note: The destination vault name is determined by the directory name
    of the configuration file.
    */ -}}
{{- $obsidian_vault_name := "knowledge-public" -}}
{{- $config_base_name := .chezmoi.configFile | dir | base -}}
{{- if eq $config_base_name "chezmoi-obsidian-public" -}}
{{-   $obsidian_vault_name = "knowledge-public" -}}
{{- else if eq $config_base_name "chezmoi-obsidian-ntt_cze_infra" }}
{{-   $obsidian_vault_name = "knowledge-ntt_cze_infra" -}}
{{- else if eq $config_base_name "chezmoi-obsidian-vbrozik" -}}
{{-   $obsidian_vault_name = "knowledge-vbrozik" -}}
{{- end -}}
# This is a chezmoi configuration file for Obsidian vaults configuration.
# It is generated from the template `{{.chezmoi.sourceDir}}/.{{base .chezmoi.configFile}}.tmpl`
# by running `chezmoi init`.

sourceDir = "~/.local/share/chezmoi-obsidian"

{{- if eq .chezmoi.os "windows" -}}
{{-   if eq .chezmoi.hostname "NTT-44Q83J3" -}}
{{/*  Special case for the old location, will be removed. */}}
destDir = "~/OneDrive - NTT Ltd/Documents/Obsidian_vaults/{{$obsidian_vault_name}}/.obsidian"
{{-   else}}
{{/*  Dev drive mounted at D: is used for vaults on Windows. */}}
destDir = "D:/obsidian_vaults/{{$obsidian_vault_name}}/.obsidian"
{{-   end -}}
{{- else}}
destDir = "~/obsidian_vaults/{{$obsidian_vault_name}}/.obsidian"
{{- end -}}
